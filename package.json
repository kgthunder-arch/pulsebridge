{
  "name": "pulsebridge",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "setup": "node scripts/automate.mjs setup",
    "check": "node scripts/automate.mjs check",
    "launch": "node scripts/automate.mjs launch",
    "dev": "concurrently \"npm --workspace server run dev\" \"npm --workspace client run dev\"",
    "build": "npm --workspace server run build && npm --workspace client run build",
    "start": "npm --workspace server run start",
    "serve": "node server/dist/index.js",
    "serve:local": "node scripts/start-local-server.mjs",
    "stop:local": "node scripts/stop-local-server.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
